# ════════════════════════════════════════════════════════
# ENVIRONMENT VARIABLES — Copy to .env (git-ignored)
# For local dev: set these, then run `mvn spring-boot:run`
# For deployment: set these in Render / Netlify dashboard
# ════════════════════════════════════════════════════════

# ── GROQ LLM (required for chatbot AI) ──
# Get a free key at https://console.groq.com
GROQ_API_KEY=gsk_YOUR_GROQ_KEY_HERE

# ── GMAIL SMTP (optional — for contact form emails) ──
# 1. Enable 2FA on your Gmail: https://myaccount.google.com/security
# 2. Create an app password: https://myaccount.google.com/apppasswords
# 3. Paste the 16-char code below (remove spaces)
MAIL_USER=your.gmail@gmail.com
MAIL_PASS=xxxxxxxxxxxx

# ── CORS (origins allowed to call the backend API) ──
# Add your deployed frontend URLs here (comma-separated)
# For local dev, this defaults to http://localhost:3399
# For production, set your Netlify URL: https://yoursite.netlify.app
ALLOWED_ORIGINS=http://localhost:3399,https://tirth.netlify.app

# ── PORT (for local dev — Render injects $PORT automatically) ──
# Leave empty or comment out for local; Render overrides it
# PORT=8090
